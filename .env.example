# REMNAWAVE Panel
PANEL_API_URL=https://your-remnawave-domain.com
# Bearer API token (role: API). PANEL_API_KEY is still read as a fallback.
PANEL_API_TOKEN=your_remnawave_api_token_here

# Default internal squad applied to every package on first run.
# Leave DEFAULT_SQUAD_UUID empty to auto-detect the "main" squad from the panel.
DEFAULT_SQUAD_UUID=
DEFAULT_SQUAD_NAME=main_squad

# API server
PORT=3100

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here
ADMIN_TELEGRAM_ID=123456789

# Legacy Celerity subscription link domain (only used to rebuild old links)
PANEL_SUB_URL=https://your-panel-domain.com

# SQLite database path (relative to project root)
DATABASE_PATH=data.db

API_BASE_URL=http://localhost:3100/
DOCS_URL=dfgdsfgsgf
DOCS_PASS=111
